# Node modules — MUST exclude client/node_modules separately or Docker
# copies your macOS binaries into the Linux container and vite build breaks
node_modules/
client/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Stale local build artifacts — always built fresh inside Docker
client/dist/
dist/

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log

# Testing
coverage/
.nyc_output/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build
dist/
build/

# Reports
reports/

# Temporary files
*.tmp
temp/
